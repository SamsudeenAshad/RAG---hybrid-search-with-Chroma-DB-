# ---- LLM provider ----
# Which provider drives the agent reasoning: "gemini" or "ollama".
LLM_PROVIDER=gemini

# ---- Embedding provider ----
# "gemini" or "ollama". Each provider uses its OWN Qdrant collection
# (<QDRANT_COLLECTION>_<provider>) sized to its vector dimension, so you must
# query with the same provider you ingested with.
EMBED_PROVIDER=gemini

# ---- Google Gemini (REQUIRED for embeddings; also default chat provider) ----
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key

# ---- Ollama (self-hosted; used when LLM_PROVIDER/EMBED_PROVIDER=ollama) ----
OLLAMA_BASE_URL=http://your-ollama-host:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBED_MODEL=mxbai-embed-large

# ---- Gemini models ----
GEMINI_CHAT_MODEL=gemini-2.5-flash
# 'pro' needs a paid Gemini key (free tier quota = 0). Use flash on free tier.
GEMINI_REASONING_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=models/gemini-embedding-001
EMBED_DIM=3072

# ---- Qdrant ----
# Local Docker: http://localhost:6533 (no key).
# Qdrant Cloud: https://<cluster>.cloud.qdrant.io  + QDRANT_API_KEY
QDRANT_URL=http://localhost:6533
QDRANT_API_KEY=
QDRANT_COLLECTION=documents

# ---- PostgreSQL ----
# Used for LangGraph checkpoints + document/chunk metadata
DATABASE_URL=postgresql://a2z:a2z@localhost:5442/a2z_hunter

# ---- Retrieval / graph tuning ----
RETRIEVAL_TOP_K=20
RERANK_TOP_N=6
SCORE_THRESHOLD=0.45
MAX_ATTEMPTS=2

# ---- Web search (keyless DuckDuckGo by default) ----
# Set WEB_SEARCH_PROVIDER=tavily and TAVILY_API_KEY=... to use Tavily instead.
WEB_SEARCH_PROVIDER=duckduckgo
TAVILY_API_KEY=

# ---- Reranker (keyless local cross-encoder via fastembed) ----
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2
SPARSE_MODEL=Qdrant/bm25

# ---- LangGraph ----
LANGGRAPH_STRICT_MSGPACK=true
